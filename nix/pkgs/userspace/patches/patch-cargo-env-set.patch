+        cmd.arg("--env-set").arg(format!("CARGO_PKG_NAME={}", pkg.name()));
+
         for (key, value) in pkg.manifest().metadata().env_vars() {
             cmd.env(key, value.as_ref());
+            cmd.arg("--env-set").arg(format!("{}={}", key, value.as_ref()));
         }
 
